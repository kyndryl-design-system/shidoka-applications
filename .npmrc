# Use the public registry so installs work the same in Cursor, VSCode, and CI.
# (Global config may point at a corporate registry that doesn't have all packages.)
registry=https://registry.npmjs.org/
# Force @storybook scope to public registry (overrides global @storybook:registry if set).
@storybook:registry=https://registry.npmjs.org/

# Allow npm install when the registry uses a corporate/self-signed certificate.
# Remove or set to true once you have proper CA config (see docs below).
strict-ssl=false

# Prefer project-local installs to avoid registry hits when possible.
# (concurrently, etc. are already devDependencies and used via node_modules/.bin.)
prefer-offline=true
